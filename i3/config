#####################
#Systemwide Settings#
#####################

#Set Modifier Key
set $mod Mod4

#Set Window Title Font
font pango:hack 14

#Set Window Title Location
title_align center

#Diasble Screen Blanking
exec --no-startup-id xset s off
exec --no-startup-id xset -dpms
exec --no-startup-id xset s noblank

#######################
#Visual Window Settings#
########################

# class                 border  bground text    indicator child_border
client.focused          #4D6BFF #4D6BFF #000000 #4D6BFF   #4D6BFF
client.focused_inactive #333333 #5F676A #FFFFFF #484E50   #5F676A
client.unfocused        #333333 #222222 #888888 #292D2E   #333333
client.urgent           #2F343A #900000 #FFFFFF #900000   #900000
client.placeholder      #000000 #0C0C0C #FFFFFF #000000   #0C0C0C

client.background       #FFFFFF

#Adds Gaps to Windows
gaps inner 15
gaps outer 15

#############################
#Start i3status (Status Bar)#
#############################

bar {
        status_command i3status
        font pango:Hack 14
	position Top
}

#############################
#Autostart Applications Here#
#############################

#Autostart XDG (Desktop Initiation)
exec --no-startup-id dex --autostart --environment i3

#Autostart i3lock (Screen Locking)
#exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock --nofork

#Autostart NetworkManager Applet
exec --no-startup-id nm-applet

#Autostart 
exec --no-startup-id picom -b

#Autostart protonvpn
exec --no-startup-id protonvpn connect

#Autostart Udiskie utility
exec --no-startup-id udiskie &

#############
#Keybindings#
#############

# Use pactl to adjust volume in PulseAudio.
set $refresh_i3status killall -SIGUSR1 i3status
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +5% && $refresh_i3status
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -5% && $refresh_i3status
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle && $refresh_i3status
bindsym XF86AudioMicMute exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle && $refresh_i3status

#Start terminal
bindsym $mod+Return exec --no-startup-id alacritty

#Start Rofi
bindsym $mod+d exec --no-startup-id "rofi -show drun"

#Start Firefox
bindsym $mod+f exec --no-startup-id firefox

#Start Sublime Text
bindsym $mod+t exec --no-startup-id subl

#Start VSCodium
bindsym $mod+v exec --no-startup-id vscodium

#Start Ranger File Manager
bindsym $mod+r exec --no-startup-id ranger

#Control Screen Brightness
bindsym $mod+Shift+Up exec --no-startup-id brightnessctl -d intel_backlight s +5%
bindsym $mod+Shift+Down exec --no-startup-id brightnessctl -d intel_backlight s 5%-

#Kill focused window
bindsym $mod+Shift+q kill

#Change Focus
bindsym $mod+Up focus up
bindsym $mod+Down focus down
bindsym $mod+Left focus left
bindsym $mod+Right focus right

#Move Focused Window
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Right move right

#Split Horizontally
bindsym $mod+Shift+h split h

#Split Vertically
bindsym $mod+Shift+v split v

#Fullscreen current focused window
bindsym $mod+Shift+f fullscreen toggle

#Reload the configuration file
bindsym $mod+Shift+c reload

#Restart i3 inplace (preserves your layout/session, can be used to upgrade i3)
bindsym $mod+Shift+r restart

#Logout of i3wm
bindsym $mod+Shift+l exec --no-startup-id i3-msg exit

#Lock Screen
bindsym $mod+l exec --no-startup-id i3lock -c 000000

####################
#Workspace Settings#
####################

#Set Variables for workspace naming
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

# switch to workspace
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

# move focused container to workspace
bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10
